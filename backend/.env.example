# ─── Server ───────────────────────────────────────────────────
SERVER_PORT=8080
ENVIRONMENT=development

# ─── Database ─────────────────────────────────────────────────
DATABASE_URL=postgres://ahet:ahet_dev@localhost:5432/ahet?sslmode=disable

# ─── Authentication ───────────────────────────────────────────
JWT_SECRET=REPLACE_WITH_LONG_RANDOM_SECRET_MIN_32_CHARS
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ─── Device Auth (ESP32) ─────────────────────────────────────
DEVICE_API_KEY=esp32-device-key-REPLACE_ME

# ─── Firebase / FCM ──────────────────────────────────────────
FCM_CREDENTIALS_JSON=/run/secrets/firebase_credentials.json

# ─── Google Calendar ─────────────────────────────────────────
GOOGLE_CALENDAR_CREDENTIALS=/run/secrets/google_calendar_credentials.json
GOOGLE_CALENDAR_ID=primary

# ─── Apple Calendar (CalDAV) ─────────────────────────────────
APPLE_CALDAV_URL=https://caldav.icloud.com
APPLE_CALDAV_USERNAME=REPLACE_WITH_APPLE_ID
APPLE_CALDAV_PASSWORD=REPLACE_WITH_APP_SPECIFIC_PASSWORD

# ─── WhatsApp Business Cloud API ─────────────────────────────
# Get these from Meta Business Manager → WhatsApp → API Setup
WHATSAPP_TOKEN=REPLACE_WITH_META_SYSTEM_USER_TOKEN
WHATSAPP_PHONE_ID=REPLACE_WITH_PHONE_NUMBER_ID
WHATSAPP_BUSINESS_ID=REPLACE_WITH_WHATSAPP_BUSINESS_ACCOUNT_ID
WHATSAPP_WEBHOOK_VERIFY_TOKEN=REPLACE_WITH_RANDOM_WEBHOOK_SECRET
